{
  "permissions": {
    "allow": ["Bash(pnpm install:*)"],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:oxlint:fix"
          }
        ]
      }
    ]
  }
}
